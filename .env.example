# ===== Backend (apps/api) =====
NODE_ENV=development
API_PORT=3000
PUBLIC_BASE_URL=http://localhost:8080

# Postgres
DATABASE_URL=postgres://swiftdrop:swiftdrop@postgres:5432/swiftdrop
PGSSLMODE=disable

# Redis
REDIS_URL=redis://redis:6379

# JWT — sign with HS256, rotate before any non-local deployment
JWT_SECRET=change-me-to-a-32-byte-random-string-min-please
JWT_TTL_SECONDS=3600

# Email (MailHog locally; swap host/port for real SMTP)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SwiftDrop <no-reply@swiftdrop.local>"
SMTP_SECURE=false

# Uploads
UPLOAD_DIR=/uploads
MAX_UPLOAD_BYTES=10485760

# Reservation timing (feat1)
RESERVATION_TTL_SECONDS=60
RESERVATION_MAX_EXTENSIONS=2
RESERVATION_SWEEP_INTERVAL_MS=5000

# Rate limits
LOGIN_RATE_PER_MIN=5
PURCHASE_RATE_PER_MIN=30

# Seed credentials (consumed by `bun run seed`)
SEED_ADMIN_EMAIL=admin@swiftdrop.local
SEED_ADMIN_PASSWORD=Admin#12345
SEED_CUSTOMER_EMAIL=customer@swiftdrop.local
SEED_CUSTOMER_PASSWORD=Customer#12345

# ===== Frontend (apps/web) =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8080
